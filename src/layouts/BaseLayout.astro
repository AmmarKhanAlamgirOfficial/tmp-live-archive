---
const { title = "TMP Live Archive" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="/assets/style/style.css">
    <link rel="stylesheet" href="/assets/style/live-archive.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div id="header-placeholder"></div>

    <main class="main-content-area">
        <slot />
    </main>

    <div id="bottom-nav-placeholder"></div>

    <script is:inline src="/assets/header-injector.js"></script>
    <script is:inline src="/assets/bottom-nav.js"></script>
    <script is:inline src="/assets/embed.js"></script>
</body>
</html>
